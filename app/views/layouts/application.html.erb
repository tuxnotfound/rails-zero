<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails Zero" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-gray-900 antialiased">
    <header class="border-b border-gray-200">
      <nav class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between">
        <%= link_to "Rails Zero", root_path, class: "font-semibold text-gray-900" %>

        <div class="flex items-center gap-4 text-sm">
          <% if user_signed_in? %>
            <%= link_to "Dashboard", dashboard_path, class: "text-gray-600 hover:text-gray-900" %>
            <%= button_to "Sign out", sign_out_path, method: :delete, class: "text-gray-500 hover:text-gray-900 bg-transparent border-0 cursor-pointer p-0" %>
          <% else %>
            <%= button_to "Sign in with GitHub", "/auth/github", method: :post, data: { turbo: false }, class: "bg-gray-900 text-white px-3 py-1.5 rounded-md hover:bg-gray-700 border-0 cursor-pointer" %>
          <% end %>
        </div>
      </nav>
    </header>

    <% if flash[:notice] %>
      <div class="bg-green-50 border-b border-green-200 px-4 py-2 text-sm text-green-800 text-center"><%= flash[:notice] %></div>
    <% end %>
    <% if flash[:alert] %>
      <div class="bg-red-50 border-b border-red-200 px-4 py-2 text-sm text-red-800 text-center"><%= flash[:alert] %></div>
    <% end %>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
